DATABASE_URL=postgresql://user:pass@localhost:5433/domicilios
POSTGRES_USER=user
POSTGRES_PASSWORD=pass
POSTGRES_DB=domicilios
APP_PASSWORD=clave-compartida-del-negocio
SESSION_SECRET=una-cadena-aleatoria-larga
SENTRY_DSN=
# Opcional: destino de rclone para el backup diario de Postgres (ver rclone.conf.example).
# Vacío = el dump solo queda en el volumen local del backup, sin copia fuera del Droplet.
RCLONE_REMOTE_PATH=
